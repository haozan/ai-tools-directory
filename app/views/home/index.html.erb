<% content_for :title, "酷律师 - 发现最佳法律AI工具" %>

<!-- Hero Section -->
<section class="gradient-surface py-20 px-4">
  <div class="container-xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-6">
        <h1 class="font-heading text-5xl lg:text-6xl font-bold text-primary leading-tight">
          酷律师 - 发现最佳法律AI工具
        </h1>
        <p class="text-xl text-secondary leading-relaxed">
          探索强大的法律AI工具,提升工作效率。从法律文书撰写到案例分析，Kulawyer为您的法律工作找到最合适的AI助手。
        </p>
        
        <!-- Search Box -->
        <%= form_with url: tools_path, method: :get, class: "relative" do |f| %>
          <%= lucide_icon "search", class: "absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted" %>
          <%= f.text_field :q, 
              placeholder: "搜索法律AI工具...", 
              class: "search-box w-full pl-12 pr-4 py-4 bg-surface-elevated border border-border rounded-xl text-primary focus:outline-none focus:border-primary transition-all" %>
        <% end %>
        
        <!-- Trending Tags -->
        <div class="flex flex-wrap gap-2">
          <span class="text-sm text-muted">热门分类:</span>
          <% ["龙虾频道", "AI 编程", "AI 阅卷", "AI 语音输出", "AI 起草文书", "AI 合同审核", "AI 写作"].each do |category_name| %>
            <% if category = @trending_categories[category_name] %>
              <%= link_to category_path(category), class: "px-3 py-1 bg-surface-elevated border border-primary/30 rounded-full text-sm text-primary hover:bg-primary/10 cursor-pointer transition-colors" do %>
                <%= category_name %>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
      
      <!-- Right: Hero Image -->
      <div class="relative">
        <div class="aspect-square rounded-2xl overflow-hidden border border-border">
          <img 
            src="https://backend-prod-hjlerckip39sk4no.s3-accelerate.amazonaws.com/images/2026/02/15/0194e09c-901f-7b99-bb46-e5b93b676708/%E4%B8%8B_%E8%BD%BD_55154586.png" 
            alt="法律 AI 科技" 
            class="w-full h-full object-cover"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <!-- Floating Stats -->
        <div class="absolute -bottom-6 -left-6 bg-surface-elevated border border-border rounded-xl p-4 shadow-xl">
          <div class="text-3xl font-bold text-primary"><%= @tools_count %>+</div>
          <div class="text-sm text-muted">AI工具</div>
        </div>
        <div class="absolute -top-6 -right-6 bg-surface-elevated border border-border rounded-xl p-4 shadow-xl">
          <div class="text-3xl font-bold text-secondary"><%= @categories_count %>+</div>
          <div class="text-sm text-muted">分类</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Tools Grid -->
<section class="py-16 px-4 bg-surface">
  <div class="container-xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h2 class="font-heading text-3xl font-bold text-primary">精选工具</h2>
      <%= link_to tools_path, class: "btn-outline text-primary hover:bg-primary/10" do %>
        查看全部
        <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
      <% end %>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @tools.each do |tool| %>
        <%= render 'shared/tool_card', tool: tool %>
      <% end %>
    </div>
  </div>
</section>




