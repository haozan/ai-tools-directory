<% content_for :title, "酷律师 - 发现最佳法律AI工具" %>

<!-- Hero Section -->
<section class="relative gradient-surface hero-grid-bg overflow-hidden">
  <!-- Background atmospheric glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/4 w-96 h-96 rounded-full opacity-10"
         style="background: radial-gradient(circle, hsl(43 72% 58%) 0%, transparent 70%); filter: blur(60px);"></div>
    <div class="absolute bottom-0 right-1/4 w-72 h-72 rounded-full opacity-8"
         style="background: radial-gradient(circle, hsl(200 80% 55%) 0%, transparent 70%); filter: blur(80px);"></div>
  </div>

  <div class="container-xl mx-auto px-4 lg:px-6 py-20 lg:py-28 relative">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Text Content -->
      <div class="space-y-8">
        <!-- Eyebrow label -->
        <div class="animate-fade-in-up">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium tracking-widest uppercase"
                style="background: hsl(43 72% 58% / 0.12); border: 1px solid hsl(43 72% 58% / 0.3); color: hsl(43 80% 70%);">
            <%= lucide_icon "scale", class: "w-3.5 h-3.5" %>
            法律 AI 工具导航
          </span>
        </div>

        <div class="animate-fade-in-up animate-delay-100">
          <h1 class="font-heading text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight tracking-tight">
            <span class="text-primary">发现最佳</span><br>
            <span class="gradient-gold">法律 AI 工具</span>
          </h1>
        </div>

        <p class="text-lg text-secondary leading-relaxed max-w-lg animate-fade-in-up animate-delay-200">
          精选法律从业者专属 AI 工具，覆盖文书起草、合同审核、案例分析、法律研究等核心场景，助力提升执业效率。
        </p>

        <!-- Search Box -->
        <div class="animate-fade-in-up animate-delay-300">
          <%= form_with url: tools_path, method: :get, class: "relative" do |f| %>
            <%= lucide_icon "search", class: "absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted pointer-events-none" %>
            <%= f.text_field :q,
                placeholder: "搜索法律AI工具，例如：合同审核...",
                class: "search-box w-full pl-12 pr-16 py-4 rounded-xl text-base",
                autofocus: false %>
            <button type="submit"
                    class="absolute right-2 top-1/2 -translate-y-1/2 btn-primary btn-sm rounded-lg px-4 py-2 text-sm">
              搜索
            </button>
          <% end %>
        </div>

        <!-- Trending Tags -->
        <div class="flex flex-wrap items-center gap-2 animate-fade-in-up animate-delay-400">
          <span class="text-xs text-muted tracking-wide uppercase">热门：</span>
          <% [["龙虾频道","🦞"], ["AI 编程","💻"], ["AI 阅卷","📋"], ["AI 语音输出","🎙"], ["AI 起草文书","📝"], ["AI 合同审核","📄"]].each do |name, emoji| %>
            <% if category = @trending_categories[name] %>
              <%= link_to category_path(category),
                  class: "category-pill inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium" do %>
                <span><%= emoji %></span>
                <span><%= name %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Right: Hero Illustration -->
      <div class="relative hidden lg:block animate-fade-in-up animate-delay-200">
        <div class="relative">
          <!-- 外层金色光晕 -->
          <div class="absolute -inset-2 rounded-3xl opacity-30"
               style="background: radial-gradient(ellipse at 60% 40%, hsl(43 72% 58% / 0.5), transparent 70%); filter: blur(16px);"></div>

          <!-- 主插画容器 -->
          <div class="relative aspect-square rounded-2xl overflow-hidden"
               style="border: 1px solid hsl(43 72% 58% / 0.2); background: hsl(222 28% 8%);">

            <svg viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
              <defs>
                <!-- 铂金渐变 -->
                <linearGradient id="h-gold" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="#F5D97A"/>
                  <stop offset="50%"  stop-color="#C9973A"/>
                  <stop offset="100%" stop-color="#E8B84B"/>
                </linearGradient>
                <!-- 铂金浅色 -->
                <linearGradient id="h-gold2" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%"   stop-color="#FDE68A" stop-opacity="1"/>
                  <stop offset="100%" stop-color="#C9973A" stop-opacity="0.4"/>
                </linearGradient>
                <!-- 蓝色科技渐变 -->
                <linearGradient id="h-blue" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="#60A5FA"/>
                  <stop offset="100%" stop-color="#3B82F6" stop-opacity="0.5"/>
                </linearGradient>
                <!-- 背景径向渐变 -->
                <radialGradient id="h-bg-glow" cx="50%" cy="45%" r="55%">
                  <stop offset="0%"   stop-color="#1e2d4a"/>
                  <stop offset="100%" stop-color="#0d1525"/>
                </radialGradient>
                <!-- 金色发光 -->
                <filter id="h-glow-gold" x="-30%" y="-30%" width="160%" height="160%">
                  <feGaussianBlur stdDeviation="3" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <!-- 柔和发光 -->
                <filter id="h-glow-soft" x="-20%" y="-20%" width="140%" height="140%">
                  <feGaussianBlur stdDeviation="6" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <!-- 网格 pattern -->
                <pattern id="h-grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
                  <path d="M 40 0 L 0 0 0 40" fill="none" stroke="hsl(43 72% 58% / 0.06)" stroke-width="0.8"/>
                </pattern>
              </defs>

              <!-- 背景 -->
              <rect width="480" height="480" fill="url(#h-bg-glow)"/>
              <!-- 网格纹理 -->
              <rect width="480" height="480" fill="url(#h-grid)"/>

              <!-- 底部环境光 -->
              <ellipse cx="240" cy="420" rx="200" ry="60"
                       fill="hsl(43 72% 58% / 0.08)" filter="url(#h-glow-soft)"/>

              <!-- ══════════════════════════════════ -->
              <!-- 中心：大天平 -->
              <!-- ══════════════════════════════════ -->

              <!-- 底座 -->
              <rect x="180" y="360" width="120" height="8" rx="4" fill="url(#h-gold)" opacity="0.9"/>
              <rect x="210" y="330" width="60" height="32" rx="3" fill="url(#h-gold)" opacity="0.7"/>
              <!-- 底座发光 -->
              <rect x="180" y="360" width="120" height="8" rx="4" fill="url(#h-gold)" opacity="0.4" filter="url(#h-glow-gold)"/>

              <!-- 主柱 -->
              <rect x="236" y="120" width="8" height="214" rx="4" fill="url(#h-gold)"/>
              <!-- 顶部圆球 -->
              <circle cx="240" cy="112" r="12" fill="url(#h-gold)" filter="url(#h-glow-gold)"/>
              <circle cx="240" cy="112" r="6" fill="#FDE68A"/>

              <!-- 横梁 -->
              <rect x="100" y="174" width="280" height="7" rx="3.5" fill="url(#h-gold)"/>
              <!-- 横梁发光 -->
              <rect x="100" y="174" width="280" height="7" rx="3.5" fill="url(#h-gold)" opacity="0.5" filter="url(#h-glow-gold)"/>

              <!-- 左链条 -->
              <line x1="130" y1="181" x2="118" y2="270" stroke="url(#h-gold2)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="130" y1="181" x2="142" y2="270" stroke="url(#h-gold2)" stroke-width="2.5" stroke-linecap="round"/>
              <!-- 左秤盘 (微下沉) -->
              <path d="M88 272 Q130 292 172 272" stroke="url(#h-gold)" stroke-width="4"
                    stroke-linecap="round" fill="none" filter="url(#h-glow-gold)"/>
              <path d="M88 272 Q130 292 172 272" stroke="url(#h-gold)" stroke-width="2" stroke-linecap="round" fill="none"/>

              <!-- 右链条 -->
              <line x1="350" y1="181" x2="338" y2="258" stroke="url(#h-gold2)" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="350" y1="181" x2="362" y2="258" stroke="url(#h-gold2)" stroke-width="2.5" stroke-linecap="round"/>
              <!-- 右秤盘 (微上抬) -->
              <path d="M308 260 Q350 280 392 260" stroke="url(#h-gold)" stroke-width="4"
                    stroke-linecap="round" fill="none" filter="url(#h-glow-gold)"/>
              <path d="M308 260 Q350 280 392 260" stroke="url(#h-gold)" stroke-width="2" stroke-linecap="round" fill="none"/>

              <!-- ══════════════════════════════════ -->
              <!-- 左秤盘内：法典图标 -->
              <!-- ══════════════════════════════════ -->
              <g transform="translate(108, 228)" opacity="0.9">
                <!-- 书本 -->
                <rect x="0" y="0" width="44" height="34" rx="3"
                      fill="none" stroke="url(#h-gold)" stroke-width="1.8"/>
                <line x1="22" y1="0" x2="22" y2="34" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.6"/>
                <line x1="6" y1="9" x2="16" y2="9" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.7"/>
                <line x1="6" y1="15" x2="16" y2="15" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.7"/>
                <line x1="6" y1="21" x2="16" y2="21" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.7"/>
                <line x1="28" y1="9" x2="38" y2="9" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.5"/>
                <line x1="28" y1="15" x2="38" y2="15" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.5"/>
                <line x1="28" y1="21" x2="38" y2="21" stroke="url(#h-gold)" stroke-width="1.2" opacity="0.5"/>
              </g>

              <!-- ══════════════════════════════════ -->
              <!-- 右秤盘内：AI 芯片图标 -->
              <!-- ══════════════════════════════════ -->
              <g transform="translate(328, 218)" opacity="0.9">
                <!-- 芯片外框 -->
                <rect x="0" y="0" width="44" height="44" rx="6"
                      fill="none" stroke="url(#h-blue)" stroke-width="1.8"/>
                <!-- 芯片内核 -->
                <rect x="12" y="12" width="20" height="20" rx="3"
                      fill="hsl(210 80% 60% / 0.15)" stroke="url(#h-blue)" stroke-width="1.2"/>
                <!-- 引脚 左 -->
                <line x1="0" y1="14" x2="-6" y2="14" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="0" y1="22" x2="-6" y2="22" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="0" y1="30" x2="-6" y2="30" stroke="url(#h-blue)" stroke-width="1.5"/>
                <!-- 引脚 右 -->
                <line x1="44" y1="14" x2="50" y2="14" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="44" y1="22" x2="50" y2="22" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="44" y1="30" x2="50" y2="30" stroke="url(#h-blue)" stroke-width="1.5"/>
                <!-- 引脚 上 -->
                <line x1="14" y1="0" x2="14" y2="-6" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="22" y1="0" x2="22" y2="-6" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="30" y1="0" x2="30" y2="-6" stroke="url(#h-blue)" stroke-width="1.5"/>
                <!-- 引脚 下 -->
                <line x1="14" y1="44" x2="14" y2="50" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="22" y1="44" x2="22" y2="50" stroke="url(#h-blue)" stroke-width="1.5"/>
                <line x1="30" y1="44" x2="30" y2="50" stroke="url(#h-blue)" stroke-width="1.5"/>
                <!-- AI 文字 -->
                <text x="22" y="26" text-anchor="middle" dominant-baseline="middle"
                      font-size="8" font-weight="bold" font-family="monospace"
                      fill="url(#h-blue)" opacity="0.9">AI</text>
              </g>

              <!-- ══════════════════════════════════ -->
              <!-- 浮动 AI 节点网络（背景装饰） -->
              <!-- ══════════════════════════════════ -->

              <!-- 节点连线 -->
              <g opacity="0.25">
                <line x1="60"  y1="60"  x2="160" y2="130" stroke="#C9973A" stroke-width="1"/>
                <line x1="160" y1="130" x2="240" y2="80"  stroke="#C9973A" stroke-width="1"/>
                <line x1="240" y1="80"  x2="340" y2="130" stroke="#C9973A" stroke-width="1"/>
                <line x1="340" y1="130" x2="420" y2="60"  stroke="#C9973A" stroke-width="1"/>
                <line x1="60"  y1="60"  x2="80"  y2="160" stroke="#C9973A" stroke-width="1"/>
                <line x1="420" y1="60"  x2="400" y2="160" stroke="#C9973A" stroke-width="1"/>
                <line x1="80"  y1="160" x2="160" y2="130" stroke="#C9973A" stroke-width="1"/>
                <line x1="400" y1="160" x2="340" y2="130" stroke="#C9973A" stroke-width="1"/>
              </g>

              <!-- 节点圆点 -->
              <circle cx="60"  cy="60"  r="4" fill="#C9973A" opacity="0.5"/>
              <circle cx="160" cy="130" r="3" fill="#C9973A" opacity="0.4"/>
              <circle cx="240" cy="80"  r="5" fill="#F5D97A" opacity="0.6" filter="url(#h-glow-gold)"/>
              <circle cx="340" cy="130" r="3" fill="#C9973A" opacity="0.4"/>
              <circle cx="420" cy="60"  r="4" fill="#C9973A" opacity="0.5"/>
              <circle cx="80"  cy="160" r="3" fill="#C9973A" opacity="0.35"/>
              <circle cx="400" cy="160" r="3" fill="#C9973A" opacity="0.35"/>

              <!-- 右下角装饰节点 -->
              <g opacity="0.2">
                <line x1="60"  y1="400" x2="140" y2="370" stroke="#C9973A" stroke-width="1"/>
                <line x1="140" y1="370" x2="180" y2="420" stroke="#C9973A" stroke-width="1"/>
                <line x1="360" y1="400" x2="420" y2="380" stroke="#C9973A" stroke-width="1"/>
              </g>
              <circle cx="60"  cy="400" r="3" fill="#C9973A" opacity="0.3"/>
              <circle cx="140" cy="370" r="2.5" fill="#C9973A" opacity="0.3"/>
              <circle cx="420" cy="380" r="3" fill="#C9973A" opacity="0.3"/>

              <!-- ══════════════════════════════════ -->
              <!-- 装饰：右上角六边形蜂窝 -->
              <!-- ══════════════════════════════════ -->
              <g transform="translate(370, 30)" opacity="0.18">
                <polygon points="20,0 40,11 40,33 20,44 0,33 0,11" fill="none" stroke="#C9973A" stroke-width="1"/>
                <polygon points="20,8 34,16 34,32 20,40 6,32 6,16" fill="none" stroke="#C9973A" stroke-width="0.6"/>
              </g>
              <g transform="translate(395, 55)" opacity="0.12">
                <polygon points="16,0 32,9 32,27 16,36 0,27 0,9" fill="none" stroke="#C9973A" stroke-width="1"/>
              </g>

              <!-- ══════════════════════════════════ -->
              <!-- 装饰：左下角圆弧线条 -->
              <!-- ══════════════════════════════════ -->
              <g opacity="0.15">
                <path d="M 20 460 Q 80 380 160 400" fill="none" stroke="#C9973A" stroke-width="1.5" stroke-dasharray="4 4"/>
                <path d="M 20 440 Q 90 360 180 390" fill="none" stroke="#C9973A" stroke-width="1" stroke-dasharray="3 6"/>
              </g>

              <!-- ══════════════════════════════════ -->
              <!-- 顶部光柱 -->
              <!-- ══════════════════════════════════ -->
              <rect x="234" y="0" width="12" height="108" rx="6"
                    fill="url(#h-gold2)" opacity="0.3" filter="url(#h-glow-soft)"/>

              <!-- ══════════════════════════════════ -->
              <!-- 浮动文字标签 -->
              <!-- ══════════════════════════════════ -->
              <!-- 左上：合同审核 -->
              <g transform="translate(28, 180)">
                <rect width="76" height="26" rx="13"
                      fill="hsl(43 72% 58% / 0.12)"
                      stroke="hsl(43 72% 58% / 0.35)" stroke-width="1"/>
                <text x="38" y="13" text-anchor="middle" dominant-baseline="middle"
                      font-size="10" font-family="sans-serif" fill="#E8B84B" opacity="0.85">合同审核</text>
              </g>
              <!-- 右上：案例分析 -->
              <g transform="translate(378, 175)">
                <rect width="76" height="26" rx="13"
                      fill="hsl(210 80% 60% / 0.1)"
                      stroke="hsl(210 80% 60% / 0.3)" stroke-width="1"/>
                <text x="38" y="13" text-anchor="middle" dominant-baseline="middle"
                      font-size="10" font-family="sans-serif" fill="#60A5FA" opacity="0.85">案例分析</text>
              </g>
              <!-- 左下：法律研究 -->
              <g transform="translate(22, 310)">
                <rect width="76" height="26" rx="13"
                      fill="hsl(43 72% 58% / 0.1)"
                      stroke="hsl(43 72% 58% / 0.3)" stroke-width="1"/>
                <text x="38" y="13" text-anchor="middle" dominant-baseline="middle"
                      font-size="10" font-family="sans-serif" fill="#E8B84B" opacity="0.8">法律研究</text>
              </g>
              <!-- 右下：文书起草 -->
              <g transform="translate(382, 310)">
                <rect width="76" height="26" rx="13"
                      fill="hsl(210 80% 60% / 0.1)"
                      stroke="hsl(210 80% 60% / 0.3)" stroke-width="1"/>
                <text x="38" y="13" text-anchor="middle" dominant-baseline="middle"
                      font-size="10" font-family="sans-serif" fill="#60A5FA" opacity="0.8">文书起草</text>
              </g>

              <!-- 底部渐变遮罩（融入背景） -->
              <defs>
                <linearGradient id="h-fade-bottom" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="80%" stop-color="transparent"/>
                  <stop offset="100%" stop-color="hsl(222 28% 8%)"/>
                </linearGradient>
              </defs>
              <rect width="480" height="480" fill="url(#h-fade-bottom)"/>
            </svg>
          </div>

          <!-- Floating Stats — tools count -->
          <div class="stat-badge absolute -bottom-5 -left-5 rounded-xl p-4">
            <div class="text-2xl font-bold gradient-gold"><%= @tools_count %>+</div>
            <div class="text-xs text-muted mt-0.5">精选 AI 工具</div>
          </div>

          <!-- Floating Stats — categories count -->
          <div class="stat-badge absolute -top-5 -right-5 rounded-xl p-4">
            <div class="text-2xl font-bold" style="color: hsl(var(--color-info));"><%= @categories_count %>+</div>
            <div class="text-xs text-muted mt-0.5">工具分类</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom divider -->
  <div class="gold-divider"></div>
</section>

<!-- Featured Tools -->
<section class="py-16 px-4 lg:px-6 bg-surface">
  <div class="container-xl mx-auto">

    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="text-xs text-muted uppercase tracking-widest mb-2 font-medium">精心挑选</p>
        <h2 class="font-heading text-3xl font-bold text-primary section-heading-accent">精选工具</h2>
      </div>
      <%= link_to tools_path,
          class: "inline-flex items-center gap-1.5 text-sm font-medium transition-colors duration-200",
          style: "color: hsl(var(--color-primary-light));" do %>
        查看全部工具
        <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
      <% @tools.each do |tool| %>
        <%= render 'shared/tool_card', tool: tool %>
      <% end %>
    </div>
  </div>
</section>
