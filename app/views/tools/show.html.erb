<% content_for :title, @tool.name %>

<!-- Breadcrumb -->
<% if @tool.categories.any? %>
  <div class="border-b border-border/50 py-3 px-4 bg-surface" style="background: hsl(var(--color-surface-elevated) / 0.5);">
    <div class="container-lg mx-auto">
      <nav class="flex items-center gap-1.5 text-xs" style="color: hsl(var(--color-text-muted));">
        <%= link_to root_path, class: "hover:text-primary transition-colors" do %>首页<% end %>
        <%= lucide_icon "chevron-right", class: "w-3 h-3 opacity-50" %>
        <%= link_to tools_path, class: "hover:text-primary transition-colors" do %>工具目录<% end %>
        <% primary_category = @tool.categories.first %>
        <% primary_category.ancestors.reverse.each do |ancestor| %>
          <%= lucide_icon "chevron-right", class: "w-3 h-3 opacity-50" %>
          <%= link_to ancestor.name, category_path(ancestor), class: "hover:text-primary transition-colors" %>
        <% end %>
        <%= lucide_icon "chevron-right", class: "w-3 h-3 opacity-50" %>
        <%= link_to primary_category.name, category_path(primary_category), class: "hover:text-primary transition-colors" %>
        <%= lucide_icon "chevron-right", class: "w-3 h-3 opacity-50" %>
        <span class="text-primary font-medium"><%= @tool.name %></span>
      </nav>
    </div>
  </div>
<% end %>

<!-- Tool Header -->
<section class="gradient-surface hero-grid-bg relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/3 w-96 h-64 rounded-full opacity-8"
         style="background: radial-gradient(circle, hsl(43 72% 58%) 0%, transparent 70%); filter: blur(80px);"></div>
  </div>

  <div class="container-lg mx-auto px-4 lg:px-6 py-14 relative">
    <div class="flex flex-col md:flex-row gap-8 items-start">

      <!-- Logo -->
      <div class="flex-shrink-0">
        <div class="w-24 h-24 rounded-2xl overflow-hidden border border-primary/30"
             style="box-shadow: var(--shadow-gold-sm);">
          <% if @tool.logo_image_url.present? %>
            <% if @tool.logo_is_icon? %>
              <div class="w-full h-full flex items-center justify-center p-3"
                   style="background: hsl(var(--color-surface-elevated));">
                <img src="<%= @tool.logo_image_url %>" alt="<%= @tool.name %>"
                     class="w-full h-full object-contain" fetchpriority="high" decoding="async" />
              </div>
            <% else %>
              <img src="<%= @tool.logo_image_url %>" alt="<%= @tool.name %>"
                   class="w-full h-full object-cover" fetchpriority="high" decoding="async" />
            <% end %>
          <% else %>
            <div class="w-full h-full flex items-center justify-center gradient-primary">
              <%= lucide_icon "scale", class: "w-10 h-10 opacity-70", style: "color: hsl(222 28% 8%);" %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Info -->
      <div class="flex-1 space-y-5">
        <div>
          <h1 class="font-heading text-4xl lg:text-5xl font-bold text-primary mb-3">
            <%= @tool.name %>
          </h1>
          <p class="text-lg text-secondary leading-relaxed max-w-2xl">
            <%= @tool.short_description %>
          </p>
        </div>

        <!-- Categories -->
        <div class="flex flex-wrap gap-2">
          <% @tool.categories.each do |category| %>
            <%= link_to category_path(category),
                class: "category-pill inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm" do %>
              <%= lucide_icon "tag", class: "w-3.5 h-3.5" %>
              <%= category.name %>
            <% end %>
          <% end %>
        </div>

        <!-- CTA -->
        <%= link_to @tool.website_url, target: "_blank", rel: "noopener noreferrer",
            class: "btn-primary inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold" do %>
          <%= lucide_icon "external-link", class: "w-4 h-4" %>
          访问官网
        <% end %>
      </div>
    </div>
  </div>
  <div class="gold-divider"></div>
</section>

<!-- Tool Content -->
<section class="py-12 px-4 lg:px-6 bg-surface">
  <div class="container-lg mx-auto">
    <div class="grid lg:grid-cols-3 gap-8">

      <!-- Main: Description -->
      <div class="lg:col-span-2">
        <div class="rounded-xl p-6 border border-border" style="background: hsl(var(--color-surface-elevated));">
          <h2 class="font-heading text-2xl font-bold text-primary mb-5 section-heading-accent">
            关于 <%= @tool.name %>
          </h2>
          <div class="prose max-w-none">
            <p class="text-secondary leading-relaxed text-base">
              <%= simple_format(@tool.long_description.presence || @tool.short_description) %>
            </p>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-5">
        <!-- Stats -->
        <div class="rounded-xl p-5 border border-border" style="background: hsl(var(--color-surface-elevated));">
          <h3 class="font-heading text-base font-bold text-primary mb-4 flex items-center gap-2">
            <%= lucide_icon "bar-chart-2", class: "w-4 h-4", style: "color: hsl(var(--color-primary));" %>
            工具数据
          </h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between py-2 border-b border-border/50">
              <span class="text-sm text-muted">浏览次数</span>
              <span class="text-sm font-semibold text-primary"><%= @tool.view_count.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse %></span>
            </div>
            <div class="flex items-center justify-between py-2">
              <span class="text-sm text-muted">收录于</span>
              <span class="text-sm font-semibold text-primary"><%= time_ago_in_words(@tool.created_at) %>前</span>
            </div>
          </div>
        </div>

        <!-- Visit CTA card -->
        <div class="rounded-xl p-5 border text-center"
             style="background: hsl(43 72% 58% / 0.06); border-color: hsl(43 72% 58% / 0.2);">
          <div class="w-10 h-10 rounded-xl gradient-primary mx-auto mb-3 flex items-center justify-center">
            <%= lucide_icon "external-link", class: "w-5 h-5", style: "color: hsl(222 28% 8%);" %>
          </div>
          <p class="text-sm text-secondary mb-3">立即体验这款工具</p>
          <%= link_to @tool.website_url, target: "_blank", rel: "noopener noreferrer",
              class: "btn-primary w-full flex items-center justify-center gap-2 rounded-lg py-2.5 text-sm" do %>
            前往官网
            <%= lucide_icon "arrow-up-right", class: "w-4 h-4" %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Related Tools -->
<% if @related_tools.any? %>
  <section class="py-12 px-4 lg:px-6 border-t border-border/50"
           style="background: hsl(var(--color-surface-elevated) / 0.3);">
    <div class="container-lg mx-auto">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-xs text-muted uppercase tracking-widest mb-2 font-medium">相关推荐</p>
          <h2 class="font-heading text-2xl font-bold text-primary">你可能也喜欢</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <% @related_tools.each do |tool| %>
          <%= render 'shared/tool_card', tool: tool %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
