<% content_for :title, "法律AI工具目录" %>

<!-- Hero Section -->
<section class="gradient-surface py-12 px-4">
  <div class="container-xl mx-auto text-center">
    <h1 class="font-heading text-4xl lg:text-5xl font-bold text-primary mb-4">
      浏览法律AI工具
    </h1>
    <p class="text-lg text-secondary max-w-2xl mx-auto">
      探索 <%= @tools_count %>+ 强大的法律AI工具，涉及 <%= @categories_count %> 个分类
    </p>
  </div>
</section>

<!-- Filter Bar -->
<section class="bg-surface border-b border-border sticky top-0 z-10 py-4 px-4">
  <div class="container-xl mx-auto">
    <%= form_with url: tools_path, method: :get, class: "flex flex-wrap gap-4 items-center" do |f| %>
      <!-- Search -->
      <div class="flex-1 min-w-[200px]">
        <div class="relative">
          <%= lucide_icon "search", class: "absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" %>
          <%= f.text_field :q, 
              value: params[:q], 
              placeholder: "搜索工具...", 
              class: "w-full pl-10 pr-4 py-2 bg-surface-elevated border border-border rounded-lg text-sm text-primary focus:outline-none focus:border-primary" %>
        </div>
      </div>
      
      <!-- Pricing Filter -->
      <%= f.select :pricing, 
          options_for_select([['所有价格', ''], ['免费', 'Free'], ['部分免费', 'Freemium'], ['付费', 'Paid']], params[:pricing]),
          {}, 
          class: "form-select bg-surface-elevated border-border text-secondary rounded-lg px-4 py-2 focus:border-primary" %>
      
      <!-- Sort -->
      <%= f.select :sort, 
          options_for_select([['最新', 'newest'], ['最热门', 'popular']], params[:sort]),
          {}, 
          class: "form-select bg-surface-elevated border-border text-secondary rounded-lg px-4 py-2 focus:border-primary" %>
      
      <%= f.submit "筛选", class: "btn-primary btn-sm" %>
    <% end %>
  </div>
</section>

<!-- Tools Grid -->
<section class="py-12 px-4 bg-surface min-h-screen">
  <div class="container-xl mx-auto">
    <% if @tools.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8">
        <% @tools.each do |tool| %>
          <%= render 'shared/tool_card', tool: tool %>
        <% end %>
      </div>
      
      <!-- Pagination -->
      <div class="flex justify-center">
        <%= paginate @tools, theme: 'tailwind' %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-surface-elevated border border-border rounded-full mb-4">
          <%= lucide_icon "search-x", class: "w-8 h-8 text-muted" %>
        </div>
        <h3 class="font-heading text-xl font-semibold text-primary mb-2">未找到工具</h3>
        <p class="text-secondary">请尝试调整筛选条件或搜索关键词</p>
      </div>
    <% end %>
  </div>
</section>
