<% content_for :title, "法律AI工具目录" %>

<!-- Page Header -->
<section class="gradient-surface hero-grid-bg relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-1/3 w-80 h-80 rounded-full opacity-8"
         style="background: radial-gradient(circle, hsl(43 72% 58%) 0%, transparent 70%); filter: blur(80px);"></div>
  </div>
  <div class="container-xl mx-auto px-4 lg:px-6 py-14 relative text-center">
    <p class="text-xs text-muted uppercase tracking-widest mb-3 font-medium">全部收录</p>
    <h1 class="font-heading text-4xl lg:text-5xl font-bold text-primary mb-4">
      法律 AI 工具目录
    </h1>
    <p class="text-secondary text-lg max-w-xl mx-auto">
      精选 <span class="gradient-gold font-semibold"><%= @tools_count %>+</span> 款工具，涵盖 <span style="color: hsl(var(--color-info));" class="font-semibold"><%= @categories_count %></span> 个专业分类
    </p>
  </div>
  <div class="gold-divider"></div>
</section>

<!-- Filter Bar -->
<div class="sticky top-0 z-10 border-b border-border/60 backdrop-blur-xl bg-surface/90">
  <div class="container-xl mx-auto px-4 lg:px-6 py-3">
    <%= form_with url: tools_path, method: :get, class: "flex flex-wrap gap-3 items-center" do |f| %>

      <!-- Search -->
      <div class="relative flex-1 min-w-[180px]">
        <%= lucide_icon "search", class: "absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none" %>
        <%= f.text_field :q,
            value: params[:q],
            placeholder: "搜索工具名称...",
            class: "search-box w-full pl-10 pr-4 py-2 rounded-lg text-sm" %>
      </div>

      <!-- Pricing Filter -->
      <%= f.select :pricing,
          options_for_select([['全部定价', ''], ['免费', 'Free'], ['部分免费', 'Freemium'], ['付费', 'Paid']], params[:pricing]),
          {},
          class: "search-box px-3 py-2 rounded-lg text-sm cursor-pointer min-w-[110px]" %>

      <!-- Sort -->
      <%= f.select :sort,
          options_for_select([['最新收录', 'newest'], ['最热门', 'popular']], params[:sort]),
          {},
          class: "search-box px-3 py-2 rounded-lg text-sm cursor-pointer min-w-[100px]" %>

      <%= f.submit "筛选", class: "btn-primary btn-sm rounded-lg px-5 py-2 text-sm cursor-pointer" %>

      <% if params[:q].present? || params[:pricing].present? || params[:sort].present? %>
        <%= link_to "清除", tools_path,
            class: "text-sm text-muted hover:text-secondary transition-colors" %>
      <% end %>
    <% end %>
  </div>
</div>

<!-- Tools Grid -->
<section class="py-12 px-4 lg:px-6 bg-surface min-h-screen">
  <div class="container-xl mx-auto">
    <% if @tools.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 mb-10">
        <% @tools.each do |tool| %>
          <%= render 'shared/tool_card', tool: tool %>
        <% end %>
      </div>

      <!-- Pagination -->
      <div class="flex justify-center">
        <%= paginate @tools, theme: 'tailwind' %>
      </div>

    <% else %>
      <div class="text-center py-24">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-5 border border-border"
             style="background: hsl(var(--color-surface-elevated));">
          <%= lucide_icon "search-x", class: "w-8 h-8 text-muted" %>
        </div>
        <h3 class="font-heading text-xl font-semibold text-primary mb-2">未找到相关工具</h3>
        <p class="text-secondary text-sm mb-6">尝试调整筛选条件或搜索关键词</p>
        <%= link_to "浏览全部工具", tools_path, class: "btn-primary btn-sm rounded-lg" %>
      </div>
    <% end %>
  </div>
</section>
