<!DOCTYPE html>
<html class="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="turbo-cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="renderer" content="webkit">
    <meta http-equiv="cleartype" content="on">
    <meta name="HandheldFriendly" content="True">
    <meta name="MobileOptimized" content="320">
    <% if @disable_error_tracking %>
      <meta name="disable-error-tracking" content="true">
    <% end %>
    <title>
    <%- if content_for?(:title) %>
      <%= yield(:title) + ' | ' + Rails.application.config.x.appname %>
    <%- else %>
      <%= Rails.application.config.x.appname %>
    <%- end %>
    </title>
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>

    <%# ── Open Graph / Twitter Card ── %>
    <% og_title       = content_for?(:og_title)       ? yield(:og_title)       : Rails.application.config.x.appname %>
    <% og_description = content_for?(:og_description) ? yield(:og_description) : "酷律师 — 为法律从业者精选的 AI 工具导航，发现最适合律师、法务的 AI 效率工具" %>
    <% og_image       = content_for?(:og_image)       ? yield(:og_image)       : "#{request.base_url}/og-default.png" %>
    <% og_url         = content_for?(:og_url)         ? yield(:og_url)         : request.original_url %>

    <meta property="og:type"        content="website">
    <meta property="og:site_name"   content="<%= Rails.application.config.x.appname %>">
    <meta property="og:title"       content="<%= og_title %>">
    <meta property="og:description" content="<%= og_description %>">
    <meta property="og:image"       content="<%= og_image %>">
    <meta property="og:image:width"  content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:url"         content="<%= og_url %>">

    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="<%= og_title %>">
    <meta name="twitter:description" content="<%= og_description %>">
    <meta name="twitter:image"       content="<%= og_image %>">

    <meta name="description" content="<%= og_description %>">

    <%= content_for?(:head) ? yield(:head) : '' %>
    
    <!-- Resource Hints for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://backend-prod-hjlerckip39sk4no.s3-accelerate.amazonaws.com">
    
    <!-- Optimized Font Loading -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet"></noscript>
    
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_include_tag 'application', type: "module" %>
    <%= favicon_link_tag asset_path("app-favicon.svg"), type: "image/svg+xml" unless Rails.env.test? %>
  </head>
  <body class="flex flex-col min-h-screen text-foreground <%= body_class %>">
    <%# ── 顶部横幅 ── %>
    <div class="w-full bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-white text-center py-2 px-4 text-sm font-medium tracking-wide">
      酷律师由
      <a href="https://qingshiying.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold hover:text-yellow-200 transition-colors">青狮营</a>
      AI 技术实现｜律师学 AI，就上
      <a href="https://qingshiying.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-semibold hover:text-yellow-200 transition-colors">青狮营</a>
    </div>
    <main class="flex-1 flex flex-col bg-surface">
      <%= render 'shared/navbar' unless @full_render %>
      <%= render 'shared/flash_messages' %>
      <%= yield %>
    </main>
    <%= render 'shared/footer' %>
    <%= render 'shared/wechat_qr_modal' %>
    <% if Rails.env.development? %>
      <div id="system-monitor-stream"
           data-controller="system-monitor"
           data-system-monitor-signed-name-value="<%= Turbo::StreamsChannel.signed_stream_name("system_monitor") %>"
           data-turbo-permanent>
      </div>
    <% end %>
  </body>
</html>
