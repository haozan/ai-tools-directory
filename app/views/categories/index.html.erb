<% content_for :title, "浏览所有分类" %>

<div class="bg-surface min-h-screen" data-controller="category-filter" data-category-filter-selected-value="all">

  <!-- Page Header -->
  <section class="gradient-surface hero-grid-bg relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 right-1/4 w-72 h-48 rounded-full opacity-8"
           style="background: radial-gradient(circle, hsl(43 72% 58%) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>
    <div class="container-xl mx-auto px-4 lg:px-6 py-12 relative">
      <p class="text-xs text-muted uppercase tracking-widest mb-2 font-medium">分类导航</p>
      <h1 class="font-heading text-3xl lg:text-4xl font-bold text-primary">浏览工具分类</h1>
    </div>
    <div class="gold-divider"></div>
  </section>

  <!-- Content: Sidebar + Grid -->
  <section class="py-8 px-4 lg:px-6">
    <div class="container-xl mx-auto">
      <div class="flex gap-6 items-start">

        <!-- Sidebar: Categories -->
        <aside class="w-72 flex-shrink-0">
          <div class="sticky top-20">
            <nav class="space-y-1.5">

              <!-- All Tools -->
              <button
                type="button"
                data-category-filter-target="categoryBtn"
                data-category-id="all"
                data-action="click->category-filter#selectCategory"
                class="w-full text-left px-4 py-3 rounded-xl border-2 border-primary bg-primary/10 flex items-center gap-3 group transition-all duration-200">
                <div class="flex items-center justify-center w-9 h-9 rounded-lg gradient-primary flex-shrink-0">
                  <%= lucide_icon "layout-grid", class: "w-4 h-4", style: "color: hsl(222 28% 8%);" %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-primary text-sm">所有工具</div>
                  <div class="text-xs text-muted mt-0.5"><%= @tools_count %> 款工具</div>
                </div>
              </button>

              <% @categories.each do |category| %>
                <div class="rounded-xl border border-border hover:border-primary/50 transition-all duration-200 overflow-hidden"
                     style="background: hsl(var(--color-surface-elevated));">
                  <div class="flex items-center">
                    <button
                      type="button"
                      data-category-filter-target="categoryBtn"
                      data-category-id="<%= category.id %>"
                      data-action="click->category-filter#selectCategory"
                      class="flex-1 text-left px-4 py-3 flex items-center gap-3 group">
                      <div class="flex items-center justify-center w-9 h-9 bg-primary/10 border border-primary/20 rounded-lg flex-shrink-0 group-hover:bg-primary/20 transition-colors">
                        <%= lucide_icon "folder", class: "w-4 h-4", style: "color: hsl(var(--color-primary));" %>
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-primary text-sm truncate"><%= category.name %></div>
                        <div class="text-xs text-muted mt-0.5"><%= category.all_tools.count %> 款</div>
                      </div>
                    </button>

                    <% if category.has_children? %>
                      <button
                        type="button"
                        data-category-id="<%= category.id %>"
                        data-action="click->category-filter#toggleChildren"
                        class="flex-shrink-0 p-3 text-muted hover:text-primary transition-colors">
                        <%= lucide_icon "chevron-right", class: "w-4 h-4 transition-transform duration-200" %>
                      </button>
                    <% end %>
                  </div>

                  <% if category.has_children? %>
                    <div
                      data-category-filter-target="childrenContainer"
                      data-parent-id="<%= category.id %>"
                      class="hidden border-t border-border/50 bg-surface/50">
                      <% category.children.each do |child| %>
                        <button
                          type="button"
                          data-category-filter-target="categoryBtn"
                          data-category-id="<%= child.id %>"
                          data-action="click->category-filter#selectCategory"
                          class="w-full text-left px-4 py-2.5 pl-12 flex items-center gap-2 group hover:bg-surface-elevated transition-colors border-b border-border/30 last:border-0">
                          <div class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: hsl(var(--color-primary) / 0.4);"></div>
                          <span class="text-sm text-secondary group-hover:text-primary transition-colors flex-1 truncate"><%= child.name %></span>
                          <span class="text-xs text-muted flex-shrink-0"><%= child.tools_count %></span>
                        </button>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>

            </nav>
          </div>
        </aside>

        <!-- Main: Tools Grid -->
        <main class="flex-1 min-w-0">
          <div data-category-filter-target="toolsContainer">
            <div data-category-filter-target="loadingPlaceholder" class="text-center py-20">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl border border-border mb-4"
                   style="background: hsl(var(--color-surface-elevated));">
                <%= lucide_icon "loader", class: "w-7 h-7 animate-spin", style: "color: hsl(var(--color-primary));" %>
              </div>
              <p class="text-sm text-muted">加载中...</p>
            </div>
            <noscript>
              <div class="text-center py-16 rounded-xl border border-border" style="background: hsl(var(--color-surface-elevated));">
                <p class="text-secondary mb-4 text-sm">请开启 JavaScript 以浏览分类工具</p>
                <%= link_to "查看全部工具", tools_path, class: "btn-primary btn-sm rounded-lg" %>
              </div>
            </noscript>
          </div>
        </main>

      </div>
    </div>
  </section>
</div>
