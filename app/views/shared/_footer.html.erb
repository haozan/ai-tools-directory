<footer class="border-t border-border/60 bg-surface">
  <!-- Top gold shimmer line -->
  <div class="gold-divider"></div>

  <div class="container-xl mx-auto px-4 lg:px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="md:col-span-2 space-y-4">
        <h3 class="font-heading text-2xl font-bold gradient-gold">
          <%= Rails.application.config.x.appname %>
        </h3>
        <p class="text-sm text-secondary leading-relaxed max-w-xs">
          面向法律从业者的 AI 工具导航平台，精选高质量工具，助力提升专业效率与竞争力。
        </p>
        <p class="text-xs text-muted">专为法律人打造 · 持续更新中</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">快速导航</h4>
        <ul class="space-y-2.5">
          <li><%= link_to "全部工具", tools_path, class: "text-sm text-secondary hover:text-primary transition-colors" %></li>
          <li><%= link_to "分类浏览", categories_path, class: "text-sm text-secondary hover:text-primary transition-colors" %></li>
          <li><%= link_to "直达资源", resources_path, class: "text-sm text-secondary hover:text-primary transition-colors" %></li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">热门分类</h4>
        <ul class="space-y-2.5">
          <% @footer_categories.each do |cat| %>
            <li>
              <%= link_to cat.name, category_path(cat),
                  class: "text-sm text-secondary hover:text-primary transition-colors" %>
            </li>
          <% end %>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-border/50 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted">
        © <%= Time.current.year %> <%= Rails.application.config.x.appname %>（酷律师）保留所有权利
      </p>
      <div class="flex items-center gap-4">
        <span class="text-xs text-muted">隐私政策</span>
        <span class="text-xs text-muted">·</span>
        <span class="text-xs text-muted">服务条款</span>
      </div>
    </div>
  </div>
</footer>
