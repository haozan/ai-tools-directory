<%= link_to tool_path(tool), class: "tool-card card bg-surface-elevated border border-border rounded-xl overflow-hidden block group hover:border-primary transition-all duration-300" do %>
  <!-- Tool Image -->
  <div class="aspect-video relative overflow-hidden bg-surface">
    <% if tool.logo_image_url.present? %>
      <img src="<%= tool.logo_image_url %>" alt="<%= tool.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async" />
    <% else %>
      <div class="w-full h-full flex items-center justify-center gradient-primary">
        <%= lucide_icon "sparkles", class: "w-12 h-12 text-white opacity-80" %>
      </div>
    <% end %>
  </div>

  <!-- Tool Info -->
  <div class="p-4 space-y-2">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-heading text-base font-semibold text-primary group-hover:text-primary-light transition-colors leading-snug">
        <%= tool.name %>
      </h3>
      <%= lucide_icon "external-link", class: "w-4 h-4 text-muted flex-shrink-0 mt-0.5" %>
    </div>

    <p class="text-sm text-secondary line-clamp-2">
      <%= tool.short_description %>
    </p>

    <% if tool.categories.any? %>
      <div class="flex flex-wrap items-center gap-1.5 pt-1">
        <% tool.categories.first(2).each do |cat| %>
          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-primary/10 border border-primary/20 rounded text-xs text-primary">
            <%= cat.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
