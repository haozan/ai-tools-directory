<%= link_to tool_path(tool), class: "tool-card rounded-xl overflow-hidden block group" do %>
  <!-- Thumbnail -->
  <div class="aspect-video relative overflow-hidden" style="background: hsl(var(--color-surface));">
    <% if tool.logo_image_url.present? %>
      <% if tool.logo_is_icon? %>
        <%# 图标类（SVG/LobeHub）：居中展示，品牌色背景，不裁剪 %>
        <div class="w-full h-full flex items-center justify-center"
             style="background: <%= tool.logo_display_bg %>;">
          <img
            src="<%= tool.logo_image_url %>"
            alt="<%= tool.name %>"
            class="w-20 h-20 object-contain group-hover:scale-110 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        </div>
      <% else %>
        <%# 普通图片：铺满裁剪 %>
        <img
          src="<%= tool.logo_image_url %>"
          alt="<%= tool.name %>"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          decoding="async"
        />
        <!-- Subtle overlay on hover -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
             style="background: linear-gradient(to top, hsl(222 28% 8% / 0.5) 0%, transparent 50%);"></div>
      <% end %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center gradient-primary">
        <%= lucide_icon "scale", class: "w-10 h-10 opacity-60", style: "color: hsl(222 28% 8%);" %>
      </div>
    <% end %>
  </div>

  <!-- Info -->
  <div class="p-4 flex flex-col gap-2" style="background: hsl(var(--color-surface-elevated)); min-height: 7.5rem;">
    <!-- 标题行 -->
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-heading text-base font-semibold text-primary group-hover:text-primary-light transition-colors leading-snug line-clamp-1">
        <%= tool.name %>
      </h3>
      <%= lucide_icon "arrow-up-right", class: "w-4 h-4 flex-shrink-0 mt-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200",
          style: "color: hsl(var(--color-primary));" %>
    </div>

    <!-- 副标题：固定 2 行高度，多余截断，不足留空 -->
    <p class="text-sm leading-relaxed line-clamp-2 flex-1" style="color: hsl(var(--color-text-secondary)); min-height: 2.5rem;">
      <%= tool.short_description %>
    </p>

    <!-- 标签：始终在底部 -->
    <% if tool.categories.any? %>
      <div class="flex flex-wrap items-center gap-1.5 mt-auto">
        <% tool.categories.first(2).each do |cat| %>
          <span class="category-pill inline-flex items-center px-2 py-0.5 rounded text-xs">
            <%= cat.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
