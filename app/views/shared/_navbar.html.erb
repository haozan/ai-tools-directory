<nav class="sticky top-0 z-50 border-b border-border/60 backdrop-blur-xl bg-surface/90" data-controller="dropdown">
  <div class="container-xl mx-auto px-4 lg:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-2.5 group flex-shrink-0" do %>
        <!-- SVG Logo：天平 + AI 节点，铂金配色 -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none"
             class="w-9 h-9 flex-shrink-0 drop-shadow-[0_0_6px_rgba(201,151,58,0.45)] group-hover:drop-shadow-[0_0_10px_rgba(201,151,58,0.7)] transition-all duration-300">
          <defs>
            <linearGradient id="nl-gold-main" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%"   stop-color="#F5D97A"/>
              <stop offset="45%"  stop-color="#C9973A"/>
              <stop offset="100%" stop-color="#E8B84B"/>
            </linearGradient>
            <linearGradient id="nl-gold-light" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%"   stop-color="#FDE68A"/>
              <stop offset="100%" stop-color="#B87333"/>
            </linearGradient>
            <linearGradient id="nl-bg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%"   stop-color="#1a2540"/>
              <stop offset="100%" stop-color="#111827"/>
            </linearGradient>
            <filter id="nl-glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="1.2" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <!-- 背景 -->
          <rect width="64" height="64" rx="14" fill="url(#nl-bg)"/>
          <rect x="1" y="1" width="62" height="62" rx="13"
                stroke="url(#nl-gold-light)" stroke-width="0.8" stroke-opacity="0.35" fill="none"/>
          <!-- 天平主柱 -->
          <circle cx="32" cy="16" r="2.2" fill="url(#nl-gold-main)" filter="url(#nl-glow)"/>
          <rect x="31.1" y="15" width="1.8" height="22" rx="0.9" fill="url(#nl-gold-main)"/>
          <rect x="22" y="37" width="20" height="2.2" rx="1.1" fill="url(#nl-gold-main)"/>
          <rect x="29.5" y="39.2" width="5" height="1.6" rx="0.8" fill="url(#nl-gold-main)" opacity="0.8"/>
          <!-- 横梁 -->
          <rect x="16" y="19.5" width="32" height="1.6" rx="0.8" fill="url(#nl-gold-main)"/>
          <!-- 左秤盘 -->
          <line x1="19" y1="21" x2="19" y2="29" stroke="url(#nl-gold-light)" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M13.5 29 Q19 31.5 24.5 29" stroke="url(#nl-gold-main)" stroke-width="1.6"
                stroke-linecap="round" fill="none" filter="url(#nl-glow)"/>
          <!-- 右秤盘 -->
          <line x1="45" y1="21" x2="45" y2="27" stroke="url(#nl-gold-light)" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M39.5 27 Q45 29.5 50.5 27" stroke="url(#nl-gold-main)" stroke-width="1.6"
                stroke-linecap="round" fill="none" filter="url(#nl-glow)"/>
          <!-- AI 节点 -->
          <circle cx="22" cy="47" r="2"   fill="url(#nl-gold-main)" opacity="0.9" filter="url(#nl-glow)"/>
          <circle cx="32" cy="44" r="2.4" fill="url(#nl-gold-main)" filter="url(#nl-glow)"/>
          <circle cx="42" cy="47" r="2"   fill="url(#nl-gold-main)" opacity="0.9" filter="url(#nl-glow)"/>
          <line x1="23.7" y1="46.2" x2="30"   y2="44.6" stroke="url(#nl-gold-light)" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
          <line x1="34"   y1="44.6" x2="40.3" y2="46.2" stroke="url(#nl-gold-light)" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
          <circle cx="32" cy="41" r="1" fill="#FDE68A" opacity="0.6"/>
          <line x1="32" y1="41.8" x2="32" y2="43.8" stroke="#FDE68A" stroke-width="0.8" opacity="0.5"/>
        </svg>
        <span class="font-heading text-lg font-semibold gradient-gold">
          <%= Rails.application.config.x.appname %>
        </span>
      <% end %>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <%= link_to categories_path, class: "text-sm text-secondary hover:text-primary transition-colors duration-200 font-medium tracking-wide" do %>
          分类浏览
        <% end %>
        <%= link_to resources_path, class: "text-sm text-secondary hover:text-primary transition-colors duration-200 font-medium tracking-wide" do %>
          直达资源
        <% end %>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <button
          data-controller="wechat-qr-trigger"
          data-action="click->wechat-qr-trigger#show"
          class="btn-primary btn-sm hidden md:inline-flex items-center gap-1.5 rounded-lg">
          <%= lucide_icon "plus", class: "w-4 h-4" %>
          提交工具
        </button>

        <!-- Mobile menu trigger -->
        <button
          class="md:hidden p-2 text-secondary hover:text-primary transition-colors"
          data-dropdown-target="trigger"
          data-action="click->dropdown#toggle"
          aria-label="Toggle menu">
          <%= lucide_icon "menu", class: "w-5 h-5" %>
        </button>
      </div>
    </div>

    <!-- Mobile Search -->
    <div class="md:hidden pb-3">
      <%= form_with url: tools_path, method: :get, class: "relative" do |f| %>
        <%= lucide_icon "search", class: "absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted pointer-events-none" %>
        <%= f.text_field :q,
            placeholder: "搜索法律AI工具...",
            class: "search-box w-full pl-10 pr-4 py-2 rounded-lg text-sm" %>
      <% end %>
    </div>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden border-t border-border/50 pb-4" data-dropdown-target="menu">
      <div class="pt-3 space-y-1">
        <%= link_to categories_path, class: "flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm text-secondary hover:text-primary hover:bg-surface-elevated transition-colors font-medium" do %>
          <%= lucide_icon "grid-3x3", class: "w-4 h-4" %>
          分类浏览
        <% end %>
        <%= link_to resources_path, class: "flex items-center gap-2 px-3 py-2.5 rounded-lg text-sm text-secondary hover:text-primary hover:bg-surface-elevated transition-colors font-medium" do %>
          <%= lucide_icon "bookmark", class: "w-4 h-4" %>
          直达资源
        <% end %>
        <div class="pt-2">
          <button
            data-controller="wechat-qr-trigger"
            data-action="click->wechat-qr-trigger#show"
            class="btn-primary btn-sm w-full flex items-center justify-center gap-2 rounded-lg">
            <%= lucide_icon "plus", class: "w-4 h-4" %>
            提交工具
          </button>
        </div>
      </div>
    </div>
  </div>
</nav>
