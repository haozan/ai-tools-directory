<%# LobeHub 图标选择器 partial %>

<%# 隐藏字段，存储品牌背景色 %>
<input type="hidden" name="tool[logo_bg_color]" id="lobe-bg-color-input"
       value="<%= @tool&.logo_bg_color.to_s %>">

<div class="mt-4 border border-gray-200 dark:border-gray-600 rounded-lg" id="lobe-icon-picker">
  <!-- 折叠标题 -->
  <button type="button"
          onclick="toggleLobePicker()"
          class="w-full flex items-center justify-between px-4 py-3 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors text-left rounded-lg"
          id="lobe-picker-toggle">
    <div class="flex items-center gap-2">
      <img src="https://cdn.jsdelivr.net/npm/@lobehub/icons-static-svg/icons/lobehub-color.svg"
           class="w-4 h-4" alt="LobeHub" onerror="this.style.display='none'">
      <span class="text-sm font-medium text-gray-700 dark:text-gray-300">从 LobeHub 图标库选择</span>
      <span class="text-xs text-gray-400 dark:text-gray-500">1400+ AI 品牌图标</span>
    </div>
    <svg id="lobe-picker-chevron" class="w-4 h-4 text-gray-400 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>

  <!-- 展开内容 -->
  <div id="lobe-picker-body" class="hidden">
    <!-- 搜索框 -->
    <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-600">
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
          </svg>
        </div>
        <input type="text"
               id="lobe-icon-search"
               placeholder="搜索图标名称，如 openai、claude、gemini…"
               class="w-full pl-9 pr-4 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
               oninput="searchLobeIcons(this.value)">
      </div>
      <p class="mt-1.5 text-xs text-gray-400 dark:text-gray-500" id="lobe-icon-hint">
        输入关键词搜索，点击图标即可填入 Logo URL
      </p>
    </div>

    <!-- 图标网格 -->
    <div id="lobe-icon-grid"
         class="grid grid-cols-6 sm:grid-cols-8 md:grid-cols-10 gap-1 p-3 max-h-72 overflow-y-auto overflow-x-hidden">
      <div class="col-span-full text-center py-6 text-sm text-gray-400" id="lobe-icon-loading">
        加载图标库中…
      </div>
    </div>

    <!-- 已选预览 -->
    <div id="lobe-selected-preview" class="hidden px-4 py-3 border-t border-gray-200 dark:border-gray-600 bg-green-50 dark:bg-green-900/20">
      <div class="flex items-center gap-3">
        <div id="lobe-selected-img-wrap" class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0 p-1.5">
          <img id="lobe-selected-img" src="" class="w-full h-full object-contain" alt="">
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-green-700 dark:text-green-300" id="lobe-selected-name"></p>
          <p class="text-xs text-gray-400 mt-0.5" id="lobe-selected-color"></p>
          <p class="text-xs text-green-600 dark:text-green-400 truncate" id="lobe-selected-url"></p>
        </div>
        <button type="button"
                onclick="clearLobeSelection()"
                class="text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 flex-shrink-0">
          取消
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  if (window.__lobePickerInit) return;
  window.__lobePickerInit = true;

  const CDN_BASE = 'https://cdn.jsdelivr.net/npm/@lobehub/icons-static-svg/icons';
  const TOC_URL  = 'https://cdn.jsdelivr.net/npm/@lobehub/icons@latest/es/toc.js';

  let allIcons = [];
  let loaded = false;

  async function loadToc() {
    if (loaded) return;
    try {
      const res  = await fetch(TOC_URL);
      const text = await res.text();
      const match = text.match(/var toc\s*=\s*(\[[\s\S]*?\]);/);
      if (match) {
        allIcons = JSON.parse(match[1]);
        loaded = true;
        renderIcons(allIcons.slice(0, 60));
        document.getElementById('lobe-icon-hint').textContent =
          `共 ${allIcons.length} 个图标，输入关键词搜索`;
      }
    } catch(e) {
      document.getElementById('lobe-icon-loading').textContent = '加载失败，请检查网络';
    }
  }

  // 图标 URL：优先 color 版，否则 mono
  function iconUrl(icon) {
    const slug = icon.title.toLowerCase().replace(/\s+/g, '-');
    return (icon.param && icon.param.hasColor)
      ? `${CDN_BASE}/${slug}-color.svg`
      : `${CDN_BASE}/${slug}.svg`;
  }

  // 品牌背景色：
  // - 有 colorGradient 的用渐变
  // - color 为纯黑 (#000 / #000000) 说明图标是白色/浅色，用深色背景
  // - 其他用品牌色（加淡化防止太亮）
  function brandBg(icon) {
    if (icon.colorGradient) return icon.colorGradient;
    const c = (icon.color || '').toLowerCase().replace(/\s/g, '');
    if (!c || c === '#000' || c === '#000000' || c === '#0d0d0d' || c === '#111' || c === '#111111') {
      return '#1a1a2e'; // 深蓝黑，白色图标清晰可见
    }
    if (c === '#fff' || c === '#ffffff') {
      return '#f3f4f6'; // 浅灰
    }
    return icon.color;
  }

  // 渲染图标网格，每个格子用品牌色做背景预览
  function renderIcons(icons) {
    const grid = document.getElementById('lobe-icon-grid');
    if (!icons.length) {
      grid.innerHTML = '<div class="col-span-full text-center py-6 text-sm text-gray-400">未找到匹配图标</div>';
      return;
    }
    grid.innerHTML = icons.map(icon => {
      const url = iconUrl(icon);
      const bg  = brandBg(icon);
      const colorData = (icon.color || '').replace(/"/g, '&quot;');
      const gradientData = (icon.colorGradient || '').replace(/"/g, '&quot;');
      return `
        <button type="button"
                title="${icon.fullTitle}"
                data-url="${url}"
                data-name="${icon.fullTitle}"
                data-color="${colorData}"
                data-gradient="${gradientData}"
                onclick="selectLobeIcon(this)"
                style="overflow:visible"
                class="lobe-icon-btn flex flex-col items-center gap-1 py-1.5 px-1 rounded-lg hover:scale-110 transition-transform group cursor-pointer">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 p-1.5"
               style="background:${bg}">
            <img src="${url}"
                 style="width:100%;height:100%;object-fit:contain;display:block"
                 alt="${icon.fullTitle}"
                 onerror="this.closest('button').style.display='none'">
          </div>
          <span class="text-[9px] text-gray-500 dark:text-gray-400 truncate w-full text-center leading-tight"
                style="max-width:52px">
            ${icon.title}
          </span>
        </button>`;
    }).join('');
  }

  window.searchLobeIcons = function(q) {
    if (!loaded) { loadToc(); return; }
    const kw = q.trim().toLowerCase();
    if (!kw) { renderIcons(allIcons.slice(0, 60)); return; }
    const results = allIcons.filter(i =>
      i.title.toLowerCase().includes(kw) ||
      i.fullTitle.toLowerCase().includes(kw) ||
      (i.desc && i.desc.toLowerCase().includes(kw))
    );
    renderIcons(results.slice(0, 100));
  };

  window.selectLobeIcon = function(btn) {
    const url      = btn.dataset.url;
    const name     = btn.dataset.name;
    const color    = btn.dataset.color    || '';
    const gradient = btn.dataset.gradient || '';

    // 决定最终存入 DB 的背景色值
    const bgValue = gradient || color || '#ffffff';

    // 填入表单字段
    const urlInput = document.querySelector('input[name="tool[logo_url]"]');
    if (urlInput) urlInput.value = url;
    const bgInput = document.getElementById('lobe-bg-color-input');
    if (bgInput) bgInput.value = bgValue;

    // 计算预览背景
    const c = color.toLowerCase().replace(/\s/g,'');
    let previewBg = bgValue;
    if (!gradient && (c === '#000' || c === '#000000' || c === '#111' || c === '#111111')) {
      previewBg = '#1a1a2e';
    }

    // 更新预览区
    const wrap = document.getElementById('lobe-selected-img-wrap');
    if (wrap) wrap.style.background = previewBg;
    document.getElementById('lobe-selected-img').src = url;
    document.getElementById('lobe-selected-name').textContent = name;
    document.getElementById('lobe-selected-color').textContent = `品牌色: ${bgValue}`;
    document.getElementById('lobe-selected-url').textContent  = url;
    document.getElementById('lobe-selected-preview').classList.remove('hidden');

    // 高亮选中
    document.querySelectorAll('.lobe-icon-btn').forEach(b => {
      b.style.outline = '';
      b.style.transform = '';
    });
    btn.style.outline = '2px solid #3b82f6';
    btn.style.outlineOffset = '2px';
    btn.style.transform = 'scale(1.15)';
  };

  window.clearLobeSelection = function() {
    const urlInput = document.querySelector('input[name="tool[logo_url]"]');
    if (urlInput) urlInput.value = '';
    const bgInput = document.getElementById('lobe-bg-color-input');
    if (bgInput) bgInput.value = '';
    document.getElementById('lobe-selected-preview').classList.add('hidden');
    document.querySelectorAll('.lobe-icon-btn').forEach(b => {
      b.style.outline = '';
      b.style.transform = '';
    });
  };

  window.toggleLobePicker = function() {
    const body    = document.getElementById('lobe-picker-body');
    const chevron = document.getElementById('lobe-picker-chevron');
    const isHidden = body.classList.contains('hidden');
    body.classList.toggle('hidden');
    chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
    if (isHidden && !loaded) loadToc();
  };
})();
</script>
