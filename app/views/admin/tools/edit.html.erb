<% content_for :title, "Edit Tool" %>

<div class="container-md">
  <div class="flex items-center space-x-4">
    <%= link_to admin_tools_path, class: "btn-ghost text-sm py-1 px-3" do %>
      <%= lucide_icon "arrow-left", class: "w-4 h-4 mr-2" %>
      Back to Tools
    <% end %>
  </div>

  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-50 mt-4 mb-8">Edit Tool</h1>

  <!-- Form -->
  <div class="card bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700">
    <div class="card-body">
      <%= form_with model: [:admin, @tool], local: true, class: "space-y-6" do |form| %>
        <!-- Name -->
        <div class="form-group">
          <%= form.label :name %>
          <%= form.text_field :name, placeholder: "Enter name..." %>
        </div>

        <!-- Website url -->
        <div class="form-group">
          <%= form.label :website_url %>
          <%= form.text_field :website_url, placeholder: "Enter website url..." %>
        </div>

        <!-- Short description -->
        <div class="form-group">
          <%= form.label :short_description %>
          <%= form.text_field :short_description, placeholder: "Enter short description..." %>
        </div>

        <!-- Long description -->
        <div class="form-group">
          <%= form.label :long_description %>
          <%= form.text_area :long_description, rows: 5, placeholder: "Enter long description..." %>
        </div>

        <!-- Logo url -->
        <div class="form-group">
          <%= form.label :logo_url, "Logo URL (自动提取或手动输入)" %>
          <%= form.text_field :logo_url, placeholder: "留空则自动从网站提取 OG 图..." %>
          <p class="text-sm text-muted mt-1">留空时，系统会自动从网站 URL 提取 Open Graph 图片</p>
        </div>

        <!-- Logo upload -->
        <div class="form-group">
          <%= form.label :logo, "或上传 Logo 图片" %>
          <%= form.file_field :logo, accept: 'image/*', class: 'form-control' %>

          <% if @tool.logo_image_url.present? %>
            <div class="mt-3 flex items-start gap-4">
              <img src="<%= @tool.logo_image_url %>" class="w-32 h-20 object-cover rounded-lg border border-gray-200 dark:border-gray-600" alt="当前图片" />
              <div>
                <p class="text-sm text-muted mb-2">当前封面图</p>
                <%= link_to refresh_og_image_admin_tool_path(@tool), method: :post,
                    data: { confirm: "将重新从网站抓取 OG 图，当前图片会被替换，确认吗？" },
                    class: "inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-lg border border-primary/40 hover:bg-primary/10 transition-colors",
                    style: "color: hsl(var(--color-primary));" do %>
                  <%= lucide_icon "refresh-cw", class: "w-3.5 h-3.5" %>
                  重新抓取 OG 图
                <% end %>
              </div>
            </div>
          <% else %>
            <div class="mt-2 flex items-center gap-3">
              <p class="text-sm text-muted">暂无封面图</p>
              <%= link_to refresh_og_image_admin_tool_path(@tool), method: :post,
                  class: "inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-lg border border-primary/40 hover:bg-primary/10 transition-colors",
                  style: "color: hsl(var(--color-primary));" do %>
                <%= lucide_icon "image", class: "w-3.5 h-3.5" %>
                立即抓取 OG 图
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Featured -->
        <div class="form-group">
          <label class="flex items-center space-x-2 cursor-pointer">
            <%= form.check_box :featured, class: 'form-checkbox w-5 h-5 text-primary' %>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">设为精选工具（显示在首页）</span>
          </label>
        </div>

        <!-- Categories -->
        <div class="form-group">
          <%= form.label :category_ids, "Categories" %>
          <%= form.select :category_ids, options_from_collection_for_select(Category.order(:name), :id, :name, @tool.category_ids), { prompt: 'Select categories...' }, { multiple: true, class: 'form-select', size: 8 } %>
        </div>

        <!-- Slug -->
        <div class="form-group">
          <%= form.label :slug %>
          <%= form.text_field :slug, placeholder: "Enter slug..." %>
        </div>

        <!-- View count -->
        <div class="form-group">
          <%= form.label :view_count %>
          <%= form.number_field :view_count, placeholder: "Enter view count..." %>
        </div>

        <!-- Form Actions -->
        <div class="flex justify-end space-x-3">
          <%= link_to admin_tool_path(@tool.id), class: "btn-ghost" do %>
            Cancel
          <% end %>
          <%= form.submit "Update Tool", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
